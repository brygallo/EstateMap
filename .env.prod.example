# ================================================================
# CONFIGURACIÓN DE PRODUCCIÓN - EstateMap
# ================================================================
# Este archivo sirve como plantilla para .env.prod
# IMPORTANTE: NO commitear .env.prod con valores reales
# ================================================================

# ----------------------------------------------------------------
# DJANGO BACKEND
# ----------------------------------------------------------------
DJANGO_SECRET_KEY=change_this_to_a_very_long_random_string_in_production
DEBUG=False
ALLOWED_HOSTS=tu-dominio.com,www.tu-dominio.com,tu-ip-servidor

# ----------------------------------------------------------------
# BASE DE DATOS - PostgreSQL (Pre-instalado en servidor)
# ----------------------------------------------------------------
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_secure_postgres_password
DB_NAME=estatedb
DB_PORT=5432

# ----------------------------------------------------------------
# MINIO - Almacenamiento de Archivos (Pre-instalado en servidor)
# ----------------------------------------------------------------
# Endpoint interno para Django
MINIO_ENDPOINT=localhost:9000

# Endpoint público para acceso desde navegador
MINIO_PUBLIC_ENDPOINT=https://tu-dominio.com:9000

# Credenciales de MinIO
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# Configuración
MINIO_USE_SSL=False
MINIO_BUCKET_NAME=estatemap

# ----------------------------------------------------------------
# FRONTEND - Next.js
# ----------------------------------------------------------------
# ⚠️ IMPORTANTE: DEBEN empezar con NEXT_PUBLIC_ para estar
# disponibles en el navegador del cliente

# URL del API (debe ser accesible desde el navegador)
NEXT_PUBLIC_API_URL=https://tu-dominio.com/api

# URL del frontend (para redirecciones, etc.)
NEXT_PUBLIC_FRONTEND_URL=https://tu-dominio.com

# ----------------------------------------------------------------
# GOOGLE OAUTH - Autenticación con Google
# ----------------------------------------------------------------
# Obtén estas credenciales desde: https://console.cloud.google.com/apis/credentials
# 1. Crea un proyecto en Google Cloud Console
# 2. Habilita Google+ API
# 3. Configura pantalla de consentimiento OAuth
# 4. Crea credenciales OAuth 2.0 (Web application)
# 5. En "Authorized JavaScript origins" agrega:
#    - https://tu-dominio.com
# 6. En "Authorized redirect URIs" agrega:
#    - https://tu-dominio.com
# 7. Copia el Client ID y Client Secret aquí

# Backend - Django
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend - Next.js (debe ser el MISMO Client ID que arriba)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ----------------------------------------------------------------
# GOOGLE ANALYTICS (Opcional)
# ----------------------------------------------------------------
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ----------------------------------------------------------------
# EMAIL - Brevo (SendInBlue) u otro proveedor SMTP
# ----------------------------------------------------------------
# Backend de email (usar smtp.EmailBackend en producción)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Configuración SMTP (ejemplo con Brevo)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# Credenciales
EMAIL_HOST_USER=tu_email@brevo.com
EMAIL_HOST_PASSWORD=tu_api_key_de_brevo

# Email remitente
DEFAULT_FROM_EMAIL=noreply@tu-dominio.com

# ----------------------------------------------------------------
# OTROS
# ----------------------------------------------------------------
# URL del frontend (usada por Django para generar links en emails)
FRONTEND_URL=https://tu-dominio.com

# IP del servidor (para configuraciones internas)
SERVER_IP=tu.ip.del.servidor

# ================================================================
# NOTAS IMPORTANTES
# ================================================================
#
# 1. NEXT_PUBLIC_* vs VITE_*
#    - Ahora usamos Next.js (no Vite)
#    - Las variables del frontend DEBEN empezar con NEXT_PUBLIC_
#
# 2. URLs y Dominios
#    - Si tienes dominio: usa HTTPS
#    - Si solo tienes IP: usa HTTP con IP y puerto
#    - IMPORTANTE: Google OAuth requiere HTTPS en producción
#
# 3. Servicios Pre-instalados
#    - PostgreSQL: Configurar DB_HOST según tu instalación
#    - MinIO: Configurar MINIO_ENDPOINT según tu instalación
#    - No necesitas Docker para estos servicios
#
# 4. Seguridad
#    - Cambiar TODOS los valores de ejemplo
#    - Usar contraseñas fuertes
#    - Mantener .env.prod en .gitignore
#
# 5. Google OAuth
#    - GOOGLE_CLIENT_ID y NEXT_PUBLIC_GOOGLE_CLIENT_ID deben ser iguales
#    - Agregar tu dominio de producción en Google Cloud Console
#    - En producción, HTTPS es obligatorio para OAuth
#    - Ver GOOGLE_OAUTH_SETUP.md para instrucciones detalladas
#
# ================================================================
